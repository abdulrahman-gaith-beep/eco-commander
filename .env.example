# Safe local overrides for eco-commander.
# This file is an example only. Copy selected lines into a private env file
# or shell profile when you intentionally want to override a default.

# Core storage and discovery.
# Most runtime files live under ECO_HOME. If unset, Python/runtime components
# default to ~/.eco; the primary installed `eco` CLI also resolves its runtime
# under ~/.eco by default.
# ECO_HOME="$HOME/.eco"
# ECO_COMMANDER_REPO=""
# ECO_WIDGET_CONFIG=""

# Public UI label
# ECO_ORG_LABEL=""

# Installers and LaunchAgents
# SWIFTBAR_PLUGIN_DIR="$HOME/Library/Application Support/SwiftBar/Plugins"
# ECO_INSTALL_LAUNCHAGENTS=0
# ECO_LAUNCHAGENTS_DIR="$HOME/Library/LaunchAgents"
# ECO_SCHEDULER_PERSIST=0
# ECO_SCHEDULER_AUTO_LOAD=0

# Optional audit and widget document paths.
# Leave unset to hide optional audit/EROR links in the widget.
# ask/research/swarm prefer gem-smart and fall back to plain gemini.
# snapshot requires a prompt library; ECO_AUDIT_ROOT overrides that library path.
# ECO_AUDIT_DIR=""
# ECO_AUDIT_ROOT=""
# ECO_EROR_SPEC=""
# ECO_DOMAIN_CHARTERS=""

# Poller, notifications, and value model
# ECO_CLAUDE_ACCOUNTS="primary"
# ECO_COMMENTS=0
# ECO_NOTIFICATIONS=1
# ECO_NOTIFY_LOG_ONLY=1
# ECO_GEMINI_DEBUG_DUMP=0
# ECO_GEMINI_OAUTH_CLIENT_ID=""
# ECO_GEMINI_OAUTH_CLIENT_SECRET=""
# ECO_VALUE_MODEL_JSON=""

# Scheduler runtime
# ECO_LOG_LEVEL=INFO
# ECO_MAX_JOBS_PER_TICK=1
# ECO_DRY_RUN=0
# ECO_CLAUDE_BIN=claude
# ECO_CODEX_BIN=codex
# ECO_GEMINI_BIN=gemini
# ECO_OLLAMA_BIN=ollama
# ECO_GEMINI_APPROVAL_MODE=plan
# ECO_GEMINI_ALLOW_EXTERNAL_INCLUDE_DIRS=0

# Recipes and alert actions
# ask/research/swarm prefer gem-smart but fall back to plain gemini when absent.
# snapshot needs Gemini CLI access and a prompt library; ECO_AUDIT_ROOT can
# point at a local override library.
# ECO_GEM_SMART_BIN=""
# GEMINI_LAYER_TIMEOUT_SEC=180
# ECO_ASK_LOCAL_MODEL="qwen3.6:latest"
# ECO_ARABIC_PROOF_MODEL=""
# ECO_ARABIC_MODEL="qwen3.6:latest"
# ECO_ARABIC_PROOF_AUTO_UNLOAD=0
# ECO_N8N_EXPECTED=1
# ECO_N8N_STATUS=""
# ECO_N8N_COMPOSE=""
# ECO_N8N_COMPOSE_DEFAULT=""
# ECO_ALERT_OPEN_TERMINAL=1
# ECO_ALERT_SHOW_CLEARED=0
# ECO_ALLOW_DIRECT_COMPLEX_FIX=0
# ECO_FORCE_MEMORY_ROUTER_MISSING=0

# Account swapping helpers
# ECO_ACCOUNT_SECURITY=security
# ECO_ACCOUNT_PGREP=pgrep
# ECO_ALLOW_KEYCHAIN_PROMPT=0
# ECO_ACCOUNT_SECURITY_STDIN_PASSWORD=0

# Hygiene thresholds
# ECO_HYGIENE_INTERVAL=30
# ECO_HYGIENE_RED_MEM_GB=3
# ECO_HYGIENE_YEL_MEM_GB=6
# ECO_HYGIENE_RED_SWAP_MB=6000
# ECO_HYGIENE_YEL_SWAP_MB=5500
# ECO_HYGIENE_RED_MCP=80
# ECO_HYGIENE_YEL_MCP=50
# ECO_HYGIENE_STUCK_MIN=20

# Snapshot and healthcheck scripts outside src/
# ECO_SNAPSHOT_DIR="$ECO_HOME/usage-snapshots"
# ECO_SNAPSHOT_CLIPBOARD=1
# ECO_SNAPSHOT_REVEAL=1
# ECO_SNAPSHOT_NOTIFY=1
# ECO_ALLOW_LIVE_CREDENTIAL_PROBE=0
# ECO_HEALTHCHECK_MACOS_SURFACES=0
# ECO_HEALTHCHECK_LIVE_RUNTIME=0

# Dashboard refresh recipe inputs outside src/
# DASHBOARD_HTML=""
# AGENTS_DIR=""
# MCP_MASTER=""
# CLAUDE_SETTINGS=""
# STATE_JSON=""
